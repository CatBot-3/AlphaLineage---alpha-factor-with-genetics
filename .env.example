# Copy to .env and fill in. .env is gitignored and must never be committed.
# A free Tiingo key lets you download fresh data; the bundled data_cache works without it.
# Get one at https://www.tiingo.com (yfinance is the fallback provider).
TIINGO_API_KEY=

# Optional: override the local data cache directory (defaults to ./data_cache).
# ALPHALINEAGE_DATA_DIR=

# Optional: where saved factors live (defaults to <data dir>/factors); also settable from the UI.
# ALPHALINEAGE_FACTORS_DIR=
